+"""
+Configurazione centralizzata del rate limiter (slowapi).
+
+Il limiter в”ңВҝ definito qui per evitare import circolari tra main.py
+e i singoli router (auth, documents, ecc.).
+
+Limiti applicati:
+  - POST /auth/login    Г”ГҘГҶ 10 tentativi/minuto per IP  (anti brute-force)
+  - POST /auth/logout   Г”ГҘГҶ  30/minuto per IP
+  - POST /documents/upload  Г”ГҘГҶ 20 upload/minuto per IP
+  - GET  /documents/search  Г”ГҘГҶ 120 ricerche/minuto per IP
+"""
+from slowapi import Limiter
+from slowapi.util import get_remote_address
+
+limiter = Limiter(key_func=get_remote_address)
