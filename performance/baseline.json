{
  "metadata": {
    "version": "1.0",
    "created": "2026-02-28",
    "description": "Performance baseline for Documentale API",
    "lastUpdated": "2026-02-28"
  },
  "baselines": {
    "api_endpoints": {
      "list_documents": {
        "endpoint": "GET /api/documents",
        "p50": 150,
        "p95": 450,
        "p99": 800,
        "throughput_rps": 100,
        "error_rate": 0.5,
        "expected_status": 200
      },
      "search_documents": {
        "endpoint": "GET /api/documents/search",
        "p50": 200,
        "p95": 550,
        "p99": 1000,
        "throughput_rps": 80,
        "error_rate": 0.5,
        "expected_status": 200
      },
      "fts_search": {
        "endpoint": "GET /api/documents/fts",
        "p50": 300,
        "p95": 900,
        "p99": 1500,
        "throughput_rps": 50,
        "error_rate": 1.0,
        "expected_status": [200, 400]
      },
      "get_document": {
        "endpoint": "GET /api/documents/:id",
        "p50": 100,
        "p95": 300,
        "p99": 500,
        "throughput_rps": 150,
        "error_rate": 2.0,
        "expected_status": [200, 404]
      },
      "filter_documents": {
        "endpoint": "GET /api/documents?status=*",
        "p50": 200,
        "p95": 500,
        "p99": 900,
        "throughput_rps": 90,
        "error_rate": 0.5,
        "expected_status": 200
      },
      "cache_test": {
        "endpoint": "GET /api/documents/cache/:id",
        "p50": 50,
        "p95": 100,
        "p99": 150,
        "throughput_rps": 500,
        "error_rate": 0.1,
        "expected_status": 200
      }
    },
    "load_scenarios": {
      "smoke_test": {
        "users": 1,
        "duration_seconds": 10,
        "spawn_rate": 1,
        "expected_pass": true,
        "description": "Quick validation test"
      },
      "load_test": {
        "users": 50,
        "duration_seconds": 300,
        "spawn_rate": 10,
        "expected_pass": true,
        "description": "Normal load baseline"
      },
      "stress_test": {
        "users": 200,
        "duration_seconds": 180,
        "spawn_rate": 20,
        "expected_pass": true,
        "description": "High load stress test"
      },
      "soak_test": {
        "users": 50,
        "duration_seconds": 3600,
        "spawn_rate": 10,
        "expected_pass": true,
        "description": "Long-running stability test"
      }
    },
    "performance_thresholds": {
      "response_time": {
        "p50_max_ms": 300,
        "p95_max_ms": 500,
        "p99_max_ms": 1000
      },
      "throughput": {
        "min_rps": 100,
        "warning_rps": 80
      },
      "errors": {
        "max_error_rate": 1.0,
        "acceptable_4xx": 2.0,
        "critical_5xx": 0.1
      },
      "resource_usage": {
        "cpu_max_percent": 80,
        "memory_max_percent": 85,
        "connection_timeout_ms": 5000
      }
    },
    "infrastructure": {
      "database": {
        "type": "PostgreSQL",
        "version": "15",
        "max_connections": 100,
        "pool_size": 20
      },
      "cache": {
        "type": "Redis",
        "version": "7",
        "ttl_seconds": 3600
      },
      "server": {
        "workers": 4,
        "timeout_seconds": 30,
        "max_request_size": 10485760
      }
    },
    "alerts": {
      "high_latency": {
        "condition": "p95 > 600ms",
        "severity": "warning"
      },
      "high_error_rate": {
        "condition": "error_rate > 2%",
        "severity": "critical"
      },
      "low_throughput": {
        "condition": "RPS < 80",
        "severity": "warning"
      },
      "memory_leak": {
        "condition": "memory_increase > 100MB in soak test",
        "severity": "critical"
      }
    }
  },
  "notes": {
    "documentation": "See performance/README.md and docs/PERFORMANCE_TESTING.md",
    "historical_data": "Run `k6 run performance/k6-tests.js -o json=results.json` to generate data",
    "trending": "Results compared against this baseline monthly",
    "updates": "Update baseline after infrastructure changes"
  }
}
